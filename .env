# =============================
# Appwrite 接続情報（フロントエンド公開値）
# =============================
# REACT_APP_* はビルド時にバンドルに埋め込まれ、ブラウザに公開される値です。
# Appwrite Project ID / Endpoint / Database ID / Bucket ID は権限で保護されている前提で、
# 公開しても安全な値のみここに置いています。
#
# サーバー側 API キー（APPWRITE_API_KEY）は .env.local に置いてください（gitignore 対象）。

# Appwrite プロジェクト ID
REACT_APP_APPWRITE_PROJECT_ID=69f144ba0005896bc8c3

# Appwrite エンドポイント（Singapore リージョン）
REACT_APP_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1

# Appwrite データベース ID
REACT_APP_APPWRITE_DATABASE_ID=69f14627000c793e5a36

# Appwrite ストレージ バケット ID
REACT_APP_APPWRITE_STORAGE_BUCKET_ID=69f1465f0003ebde6dc6
