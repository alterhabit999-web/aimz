# =============================
# Appwrite 接続情報
# =============================
# このファイルをコピーして .env という名前で保存してください
# .env は Git に上げないよう .gitignore に設定済みです

# Appwrite プロジェクト ID（Appwrite コンソールで確認）
REACT_APP_APPWRITE_PROJECT_ID=YOUR_PROJECT_ID

# Appwrite エンドポイント（クラウド版はこのまま使用）
REACT_APP_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Appwrite データベース ID（DB作成後に設定）
REACT_APP_APPWRITE_DATABASE_ID=YOUR_DATABASE_ID

# Appwrite ストレージ バケット ID（ファイル保存用）
REACT_APP_APPWRITE_STORAGE_BUCKET_ID=YOUR_BUCKET_ID

# =============================
# サーバ管理用 API キー（npm run setup:appwrite でのみ使用）
# =============================
# Appwrite Console > Settings > API Keys で発行
# 必要スコープ：databases.read / databases.write
#                collections.read / collections.write
#                attributes.read  / attributes.write
#                indexes.read     / indexes.write
#                documents.read   / documents.write
# このキーはサーバ専用なので絶対にクライアントコードに埋め込まないこと。
APPWRITE_API_KEY=YOUR_SERVER_API_KEY
